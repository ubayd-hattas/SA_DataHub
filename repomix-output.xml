              <div className="grid grid-cols-1 gap-4 sm:grid-cols-2">
                {related.map((s) => (
                  <StoryCard key={s.slug} story={s} />
                ))}
              </div>
            </div>
          </div>
        )}
      </div>
    </div>
  )
}
